"nudge_staying_up_late_notification_6" = "Largue o celular. Agora.";
"nudge_staying_up_late_notification_7" = "Seu eu do futuro está te observando. O que ele vê?";
"nudge_staying_up_late_notification_8" = "Dormir não é opcional. É remédio.";
"nudge_staying_up_late_notification_9" = "A tela pode esperar. Seus sonhos não.";
"nudge_staying_up_late_notification_10" = "Cada hora de sono = decisões melhores amanhã.";
"nudge_staying_up_late_detail_6" = "Sua força de vontade está no nível mais baixo agora. Não lute contra a vontade de rolar a tela — tire o celular de perto. Coloque em outro cômodo.";
"nudge_staying_up_late_detail_7" = "Imagine acordar descansado vs. acordar exausto. Qual versão do amanhã você quer? Você decide agora.";
"nudge_staying_up_late_detail_8" = "O sono repara o cérebro, consolida memórias e reseta emoções. Pular isso é como pular a manutenção de um carro que você usa todo dia.";
"nudge_staying_up_late_detail_9" = "A luz azul está dizendo ao seu cérebro que é meio-dia. Seu corpo está confuso. Ajude-o guardando a tela.";
"nudge_staying_up_late_detail_10" = "Uma hora de sono hoje = 3 horas de produtividade amanhã. A conta é simples. Vá dormir.";

/* NudgeContent - cant_wake_up */
"nudge_cant_wake_up_notification_1" = "Seu dia não começa até você levantar.";
