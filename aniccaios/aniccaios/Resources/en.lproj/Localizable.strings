"nudge_staying_up_late_notification_22" = "Nothing on your phone is worth losing sleep.";
"nudge_staying_up_late_notification_23" = "Your pillow is waiting. Go.";
"nudge_staying_up_late_notification_24" = "Morning you will thank tonight you.";
"nudge_staying_up_late_notification_25" = "Stop. Breathe. Sleep.";
"nudge_staying_up_late_notification_26" = "Your brain can't repair while scrolling.";
"nudge_staying_up_late_notification_27" = "One more video won't make you happier.";
"nudge_staying_up_late_notification_28" = "Tired people make terrible decisions.";
"nudge_staying_up_late_notification_29" = "The night is for rest, not regret.";
"nudge_staying_up_late_notification_30" = "Your alarm will ring whether you sleep or not.";
"nudge_staying_up_late_notification_31" = "Sleep is the best investment you can make.";
"nudge_staying_up_late_notification_32" = "Let go of today. Tomorrow needs you fresh.";
"nudge_staying_up_late_notification_33" = "You're borrowing energy from tomorrow.";
"nudge_staying_up_late_notification_34" = "The scroll hole has no bottom. Get out now.";
