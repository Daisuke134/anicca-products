/* NudgeContent - staying_up_late */
"nudge_staying_up_late_notification_1" = "Respire, ne scrolle pas.";
"nudge_staying_up_late_notification_2" = "Combien d'années perdues à cause de « encore 5 minutes » ?";
"nudge_staying_up_late_notification_3" = "Le toi de demain va regretter.";
"nudge_staying_up_late_detail_1" = "Éloigne ton téléphone à 30 cm de ton visage. Baisse la luminosité au minimum. Prends 5 grandes respirations. Ton cerveau passera en mode « préparation au sommeil ».";
"nudge_staying_up_late_detail_2" = "Un cerveau en manque de sommeil a le même jugement qu'avec 0.1% d'alcool dans le sang. 17 heures éveillé = légalement ivre. Protège les décisions de demain en dormant ce soir.";
"nudge_staying_up_late_detail_3" = "Tu te souviendras de ce contenu demain midi ? Pourtant, le manque de sommeil va baisser ta concentration, ton jugement et ton immunité. Qu'est-ce qui compte le plus ?";

/* NudgeContent - staying_up_late (Midnight - Strong Messages) */
"nudge_staying_up_late_notification_4" = "Minuit est passé. Ton corps a besoin de repos.";
"nudge_staying_up_late_notification_5" = "Il est 1h du matin. Chaque minute éveillée te coûte demain.";
"nudge_staying_up_late_detail_4" = "Le manque de sommeil s'accumule comme une dette. L'heure perdue ce soir volera ta concentration la semaine prochaine. Éloigne ton téléphone du lit. Ferme les yeux.";
"nudge_staying_up_late_detail_5" = "Rester éveillé après 1h du matin cause des dommages mesurables à ton cerveau et ton cœur. Ce que tu fais est 100 fois moins important que dormir. Va te coucher.";

/* NudgeContent - staying_up_late (Phase 5 expansion) */
"nudge_staying_up_late_notification_6" = "Pose ton téléphone. Maintenant.";
"nudge_staying_up_late_notification_7" = "Ton futur toi te regarde. Que voit-il ?";
"nudge_staying_up_late_notification_8" = "Le sommeil n'est pas un luxe. C'est un médicament.";
"nudge_staying_up_late_notification_9" = "L'écran peut attendre. Tes rêves, non.";
"nudge_staying_up_late_notification_10" = "Chaque heure de sommeil = de meilleures décisions demain.";
"nudge_staying_up_late_detail_6" = "Ta volonté est au plus bas en ce moment. Ne lutte pas contre l'envie de scroller — retire le téléphone. Mets-le dans une autre pièce.";
"nudge_staying_up_late_detail_7" = "Imagine te réveiller reposé contre te réveiller épuisé. Quelle version de demain tu veux ? Tu décides maintenant.";
"nudge_staying_up_late_detail_8" = "Le sommeil répare ton cerveau, consolide ta mémoire et réinitialise tes émotions. Le sauter, c'est comme sauter l'entretien d'une voiture que tu conduis chaque jour.";
"nudge_staying_up_late_detail_9" = "La lumière bleue dit à ton cerveau qu'il est midi. Ton corps est perdu. Aide-le en posant l'écran.";
"nudge_staying_up_late_detail_10" = "Une heure de sommeil ce soir = 3 heures de productivité demain. Le calcul est simple. Va dormir.";

/* NudgeContent - cant_wake_up */
"nudge_cant_wake_up_notification_1" = "Ta journée ne commence pas tant que tu ne te lèves pas.";
"nudge_cant_wake_up_notification_2" = "Le toi qui dit « encore 5 minutes » n'a aucune crédibilité.";
"nudge_cant_wake_up_notification_3" = "Reste médiocre";
"nudge_cant_wake_up_notification_4" = "Les pieds au sol. 5, 4, 3, 2, 1.";
"nudge_cant_wake_up_notification_5" = "La couette te ment.";
"nudge_cant_wake_up_notification_6" = "Ton réveil est une promesse. Tiens-la.";
"nudge_cant_wake_up_notification_7" = "Gagner le matin construit la confiance.";
"nudge_cant_wake_up_notification_8" = "Lève-toi maintenant, ou regrette à midi.";
"nudge_cant_wake_up_detail_1" = "Compte 5, 4, 3, 2, 1 et pose tes pieds au sol. Bouge avant de réfléchir. Lève-toi avant que ton cerveau trouve des excuses. Rien ne change sous la couette.";
"nudge_cant_wake_up_detail_2" = "Combien de fois tu as fait confiance au toi « encore 5 minutes » ? Combien de fois tu as été trahi ? Te lever maintenant, c'est tenir une promesse envers toi-même. Tu aimeras le toi d'aujourd'hui.";
"nudge_cant_wake_up_detail_3" = "Encore une journée qui commence mal ? Ou tu changes maintenant ? Ton action dans les 5 prochaines secondes décide. Lève-toi.";
"nudge_cant_wake_up_detail_4" = "Ton corps est réveillé. Ton esprit cherche des excuses. Ignore-le. Les pieds au sol. Maintenant.";
"nudge_cant_wake_up_detail_5" = "La couette semble rassurante, mais c'est un piège. Le confort maintenant = le regret plus tard. Arrache la couette comme un pansement.";
"nudge_cant_wake_up_detail_6" = "Chaque matin où tu appuies sur snooze, tu trahis une promesse envers toi-même. Les petites trahisons s'accumulent. Commence ta journée avec intégrité.";
"nudge_cant_wake_up_detail_7" = "Ceux qui gagnent le matin gagnent la journée. Ceux qui gagnent la journée gagnent la semaine. Tout commence en se levant à l'heure prévue.";
"nudge_cant_wake_up_detail_8" = "Le toi de midi sera reconnaissant. Le toi du soir sera fier. Mais seulement si le toi du matin se lève maintenant.";

/* NudgeContent - self_loathing */
"nudge_self_loathing_notification_1" = "Tu es en vie aujourd'hui. C'est suffisant.";
"nudge_self_loathing_notification_2" = "Tu as le droit d'arrêter de te blâmer.";
"nudge_self_loathing_notification_3" = "Tu es bien meilleur que ce que tu crois.";
"nudge_self_loathing_notification_4" = "L'autocritique ne te rendra pas meilleur. La compassion, oui.";
"nudge_self_loathing_notification_5" = "Tu dirais ça à un ami ? Alors ne te le dis pas.";
"nudge_self_loathing_notification_6" = "Tu essaies. C'est ce qui compte.";
"nudge_self_loathing_notification_7" = "Ta valeur ne se mesure pas à ta productivité.";
"nudge_self_loathing_notification_8" = "Sois doux avec toi-même. Juste aujourd'hui.";
"nudge_self_loathing_detail_1" = "Te détester prouve que tu veux t'améliorer. Mais l'autocritique ne mène pas à la croissance — elle est contre-productive. Tu t'es réveillé aujourd'hui. C'est suffisant.";
"nudge_self_loathing_detail_2" = "Si ton meilleur ami était dans ta situation, tu lui dirais quoi ? Tu ne dirais pas « tu ne vaux rien ». Accorde-toi la même bienveillance.";
"nudge_self_loathing_detail_3" = "Ce que tu te reproches est vraiment « irréparable » ? La plupart des choses sont plus petites qu'elles n'en ont l'air. Respire et regarde objectivement.";
"nudge_self_loathing_detail_4" = "Les études montrent que l'autocompassion favorise plus la croissance que l'autocritique. Être dur avec toi ne marche pas. Essaie la bienveillance.";
"nudge_self_loathing_detail_5" = "Tu ne laisserais personne parler à ton ami comme ça. Pourquoi tu te permets de te parler ainsi ? Protège-toi comme tu protégerais un ami.";
"nudge_self_loathing_detail_6" = "Le progrès n'est pas linéaire. Les mauvais jours n'effacent pas les bons. Tu essaies, et c'est déjà plus que la plupart des gens.";
"nudge_self_loathing_detail_7" = "Tu n'es pas ta productivité. Tu n'es pas tes réussites. Tu mérites l'amour et le repos simplement en existant.";
"nudge_self_loathing_detail_8" = "Juste aujourd'hui, parle-toi comme tu parlerais à quelqu'un que tu aimes. Juste aujourd'hui. Demain tu pourras redevenir dur avec toi si tu veux.";

/* NudgeContent - rumination */
"nudge_rumination_notification_1" = "Que ressens-tu en ce moment ?";
"nudge_rumination_notification_2" = "Es-tu présent ici et maintenant ?";
"nudge_rumination_notification_3" = "Et si tu méditais 5 minutes ?";
"nudge_rumination_notification_4" = "La boucle est un piège. Sors-en.";
"nudge_rumination_notification_5" = "Sens tes pieds. Sens le sol. Tu es ici.";
"nudge_rumination_notification_6" = "Y penser ne changera rien.";
"nudge_rumination_notification_7" = "Nomme 5 choses que tu vois. Maintenant.";
"nudge_rumination_notification_8" = "Tes pensées ne sont pas des faits.";
"nudge_rumination_detail_1" = "Dès que tu remarques la boucle, tu es à mi-chemin. Maintenant : concentre-toi sur la plante de tes pieds. La dureté du sol, sa température. 30 secondes seulement.";
"nudge_rumination_detail_2" = "Nomme 5 choses que tu vois, 4 que tu entends, 3 que tu touches, 2 que tu sens, 1 que tu goûtes. Ça te ramène au « maintenant ».";
"nudge_rumination_detail_3" = "Le moyen le plus efficace de stopper la rumination est la méditation. Pendant 2 minutes, concentre-toi sur ta respiration. Inspire 4 sec, retiens 4 sec, expire 4 sec.";
"nudge_rumination_detail_4" = "Tu as déjà été dans cette boucle. Ça n'a jamais rien résolu. La seule sortie est de faire quelque chose de physique. Lève-toi. Bouge.";
"nudge_rumination_detail_5" = "Tes pieds sont au sol. Tes poumons respirent. Tu es ici, en ce moment, en sécurité. Le passé est terminé. Le futur n'est pas encore là.";
"nudge_rumination_detail_6" = "La rumination, c'est ton cerveau qui essaie de résoudre un problème insoluble. Ça ne se résout pas en y pensant. Accepte-le et lâche prise.";
"nudge_rumination_detail_7" = "Regarde autour de toi. Nomme ce que tu vois. « Chaise. Fenêtre. Lumière. Livre. » Ce simple geste te sort de ta tête et te ramène à la réalité.";
"nudge_rumination_detail_8" = "Les pensées sont comme des nuages. Elles passent. Tu n'as pas besoin de les attraper, les analyser ou les suivre. Regarde-les passer.";

/* NudgeContent - procrastination */
"nudge_procrastination_notification_1" = "Juste 5 minutes. C'est tout ce qu'il faut.";
"nudge_procrastination_notification_2" = "Encore une promesse à toi-même brisée ?";
"nudge_procrastination_notification_3" = "Chaque raison de ne pas le faire est une excuse.";
"nudge_procrastination_notification_4" = "Commence mal. Améliore après.";
"nudge_procrastination_notification_5" = "Le plus dur, ce sont les 2 premières minutes.";
"nudge_procrastination_notification_6" = "Que dirais-tu à un ami qui reporte sans cesse ?";
"nudge_procrastination_notification_7" = "Fait vaut mieux que parfait.";
"nudge_procrastination_notification_8" = "Le toi du futur compte sur le toi du présent.";
"nudge_procrastination_detail_1" = "Si ça prend moins de 2 minutes, fais-le maintenant. Si c'est plus long, fais juste les 2 premières minutes. Une fois lancé, ton cerveau voudra continuer. C'est scientifique.";
"nudge_procrastination_detail_2" = "Imagine-toi dans une semaine. « Si seulement je l'avais fait... » Des regrets ? Fais-le maintenant et ce regret disparaît.";
"nudge_procrastination_detail_3" = "« Je ne peux pas » et « je ne veux pas » sont différents. Lequel c'est là ? Si tu ne veux pas, pourquoi ? Trouve la vraie raison.";
"nudge_procrastination_detail_4" = "Le perfectionnisme est de la procrastination déguisée. Un début bancal est infiniment mieux que pas de début. Écris une mauvaise phrase. Fais un pas imparfait.";
"nudge_procrastination_detail_5" = "Ton cerveau déteste commencer. Mais après 2 minutes, l'élan prend le relais. Survie juste aux 2 premières minutes.";
"nudge_procrastination_detail_6" = "Si ton ami repoussait sans cesse quelque chose d'important, tu lui dirais de commencer. Sois cet ami pour toi-même maintenant.";
"nudge_procrastination_detail_7" = "Termine vaut mieux que parfait. Un projet fini avec des défauts bat un « chef-d'œuvre » inachevé à chaque fois.";
"nudge_procrastination_detail_8" = "Le toi du futur te regarde. Il est soit reconnaissant que tu aies commencé, soit frustré que tu ne l'aies pas fait. Rends-le reconnaissant.";

/* NudgeContent - anxiety */
"nudge_anxiety_notification_1" = "En ce moment, tu es en sécurité.";
"nudge_anxiety_notification_2" = "Que ressens-tu en ce moment ?";
"nudge_anxiety_notification_3" = "Respire. Inspire 4, retiens 4, expire 4.";
"nudge_anxiety_notification_4" = "L'anxiété ment. Là, tu vas bien.";
"nudge_anxiety_notification_5" = "Sens tes pieds. Tu es ancré.";
