"nudge_anger_notification_51" = "Transforma la energía de la ira en ejercicio.";
"nudge_anger_notification_52" = "Elige tus palabras. Una vez dichas, no vuelven.";
"nudge_anger_notification_53" = "El otro no va a cambiar. Tú sí puedes.";
"nudge_anger_notification_54" = "El 90% de la ira viene de cansancio, hambre o falta de sueño.";
"nudge_anger_notification_55" = "Inhala 4, retén 7, exhala 8. Repite 3 veces.";
"nudge_anger_notification_56" = "¿Dónde sientes la ira en el cuerpo? Obsérvala.";
"nudge_anger_notification_57" = "Cuenta los momentos en que controlaste tu ira hoy.";
