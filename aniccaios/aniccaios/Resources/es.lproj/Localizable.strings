"nudge_staying_up_late_detail_5" = "Estar despierto después de la 1 AM causa daño medible a tu cerebro y corazón. Lo que estás haciendo es 100 veces menos importante que dormir. Vete a la cama ya.";

/* NudgeContent - staying_up_late (Phase 5 expansion) */
"nudge_staying_up_late_notification_6" = "Suelta el celular. Ahora.";
"nudge_staying_up_late_notification_7" = "Tu yo del futuro te está mirando. ¿Qué ve?";
"nudge_staying_up_late_notification_8" = "Dormir no es opcional. Es medicina.";
"nudge_staying_up_late_notification_9" = "La pantalla puede esperar. Tus sueños no.";
"nudge_staying_up_late_notification_10" = "Cada hora de sueño = mejores decisiones mañana.";
"nudge_staying_up_late_detail_6" = "Tu fuerza de voluntad está en su punto más bajo ahora. No luches contra las ganas de scrollear — simplemente quita el celular. Ponlo en otra habitación.";
"nudge_staying_up_late_detail_7" = "Imagina despertar descansado vs. despertar agotado. ¿Qué versión de mañana quieres? Lo decides ahora mismo.";
"nudge_staying_up_late_detail_8" = "Dormir repara tu cerebro, consolida recuerdos y reinicia emociones. Saltártelo es como saltarte el mantenimiento de un auto que usas todos los días.";
"nudge_staying_up_late_detail_9" = "La luz azul le dice a tu cerebro que es mediodía. Tu cuerpo está confundido. Ayúdalo dejando la pantalla.";
"nudge_staying_up_late_detail_10" = "Una hora de sueño esta noche = 3 horas de productividad mañana. La cuenta es simple. Vete a dormir.";

/* NudgeContent - cant_wake_up */
"nudge_cant_wake_up_notification_1" = "Tu día no empezará hasta que te levantes.";
"nudge_cant_wake_up_notification_2" = "Tu yo de 'solo 5 minutos más' no tiene credibilidad.";
"nudge_cant_wake_up_notification_3" = "Quédate siendo mediocre";
"nudge_cant_wake_up_notification_4" = "Pies en el suelo. 5, 4, 3, 2, 1.";
"nudge_cant_wake_up_notification_5" = "La cobija te está mintiendo.";
"nudge_cant_wake_up_notification_6" = "Tu alarma es una promesa. Cúmplela.";
"nudge_cant_wake_up_notification_7" = "Las victorias de la mañana construyen confianza.";
"nudge_cant_wake_up_notification_8" = "Levántate ahora, o arrepiéntete al mediodía.";
"nudge_cant_wake_up_detail_1" = "Cuenta 5, 4, 3, 2, 1 y pon los pies en el suelo. Muévete antes de pensar. Levántate antes de que tu cerebro ponga excusas. Nada cambia debajo de la cobija.";
"nudge_cant_wake_up_detail_2" = "¿Cuántas veces has confiado en tu yo de '5 minutos más'? ¿Cuántas veces te traicionó? Levantarte ahora es cumplir una promesa contigo. Te va a gustar el tú de hoy.";
"nudge_cant_wake_up_detail_3" = "¿Empezar otro día a medias? ¿O cambiar desde ahora? Tu acción en los próximos 5 segundos decide. Levántate.";
"nudge_cant_wake_up_detail_4" = "Tu cuerpo ya está despierto. Tu mente está poniendo excusas. Supérala. Pies en el suelo. Ahora.";
"nudge_cant_wake_up_detail_5" = "La cobija se siente segura, pero es una trampa. Comodidad ahora = arrepentimiento después. Arranca la cobija como una curita.";
"nudge_cant_wake_up_detail_6" = "Cada mañana que pospones la alarma, rompes una promesa contigo. Las pequeñas traiciones se acumulan. Empieza hoy con integridad.";
"nudge_cant_wake_up_detail_7" = "Los que ganan las mañanas ganan los días. Los que ganan los días ganan las semanas. Todo empieza con levantarte cuando dijiste que lo harías.";
"nudge_cant_wake_up_detail_8" = "Tu yo del mediodía estará agradecido. Tu yo de la noche estará orgulloso. Pero solo si tu yo de la mañana se levanta ahora.";

/* NudgeContent - self_loathing */
"nudge_self_loathing_notification_1" = "Hoy estás vivo. Con eso basta.";
"nudge_self_loathing_notification_2" = "Está bien dejar de culparte.";
"nudge_self_loathing_notification_3" = "Eres mucho mejor persona de lo que crees.";
"nudge_self_loathing_notification_4" = "La autocrítica no te mejorará. La compasión sí.";
"nudge_self_loathing_notification_5" = "¿Le dirías eso a un amigo? Entonces no te lo digas a ti.";
"nudge_self_loathing_notification_6" = "Estás intentándolo. Eso es lo que importa.";
"nudge_self_loathing_notification_7" = "Tu valor no se mide por tu productividad.";
"nudge_self_loathing_notification_8" = "Sé amable contigo. Solo por hoy.";
"nudge_self_loathing_detail_1" = "Odiarte a ti mismo demuestra que quieres ser mejor. Pero la autocrítica no lleva al crecimiento — es contraproducente. Hoy despertaste. Con eso basta.";
"nudge_self_loathing_detail_2" = "Si tu mejor amigo estuviera en tu situación, ¿qué le dirías? No le dirías 'No vales nada.' Date la misma amabilidad.";
"nudge_self_loathing_detail_3" = "Lo que te estás reprochando, ¿realmente es 'irreparable'? La mayoría de las cosas son más pequeñas de lo que se sienten. Respira profundo y mira con objetividad.";
"nudge_self_loathing_detail_4" = "Las investigaciones muestran que la autocompasión genera más crecimiento que la autocrítica. Ser duro contigo no funciona. Prueba con la amabilidad.";
"nudge_self_loathing_detail_5" = "No dejarías que nadie le hablara así a tu amigo. ¿Por qué te permites hablarte así? Protégete como protegerías a un amigo.";
"nudge_self_loathing_detail_6" = "El progreso no es lineal. Los días malos no borran los buenos. Estás intentándolo, y eso es más de lo que hace la mayoría.";
"nudge_self_loathing_detail_7" = "No eres tu productividad. No eres tus logros. Mereces amor y descanso solo por existir.";
"nudge_self_loathing_detail_8" = "Solo por hoy, háblate como le hablarías a alguien que amas. Solo por hoy. Mañana puedes volver a ser duro contigo si quieres.";

/* NudgeContent - rumination */
"nudge_rumination_notification_1" = "¿Qué estás sintiendo ahora mismo?";
"nudge_rumination_notification_2" = "¿Estás presente en este momento?";
"nudge_rumination_notification_3" = "¿Por qué no meditar 5 minutos?";
