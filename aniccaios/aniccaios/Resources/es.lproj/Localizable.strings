"nudge_bad_mouthing_notification_16" = "El chisme envenena más al chismoso.";
"nudge_bad_mouthing_notification_17" = "¿Lo dirías en su cara?";
"nudge_bad_mouthing_notification_18" = "Habla como si estuvieran escuchando.";
"nudge_bad_mouthing_notification_19" = "Quejarte no cambia nada.";
"nudge_bad_mouthing_notification_20" = "Si no puedes ayudar, no hagas daño.";
