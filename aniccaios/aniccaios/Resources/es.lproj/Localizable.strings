"nudge_bad_mouthing_notification_38" = "Sé quien defiende a los ausentes.";
"nudge_bad_mouthing_notification_39" = "La amargura es veneno que tú mismo bebes.";
"nudge_bad_mouthing_notification_40" = "Enfócate en tu crecimiento, no en sus defectos.";
"nudge_bad_mouthing_notification_41" = "Tu lengua puede construir o destruir. Elige.";
"nudge_bad_mouthing_notification_42" = "¿Hablaron mal de ti? No pases la cadena.";
"nudge_bad_mouthing_notification_43" = "Silencia al crítico. Despierta al alentador.";
"nudge_bad_mouthing_notification_44" = "El juicio crea distancia. La empatía crea conexión.";
"nudge_bad_mouthing_notification_45" = "Elogia a alguien hoy. De corazón.";
"nudge_bad_mouthing_notification_46" = "Tus palabras plantan semillas. Planta buenas.";
"nudge_bad_mouthing_notification_47" = "Piensa dos veces. Habla una.";
"nudge_bad_mouthing_notification_48" = "El impulso de criticar suele reflejar inseguridad.";
"nudge_bad_mouthing_notification_49" = "Elévate sobre la conversación.";
"nudge_bad_mouthing_notification_50" = "Elige ser una persona segura.";
"nudge_bad_mouthing_notification_51" = "Tu reputación es lo que dices de otros.";
"nudge_bad_mouthing_notification_52" = "Rompe el ciclo. Habla vida.";
"nudge_bad_mouthing_notification_53" = "La compasión siempre es la respuesta correcta.";
"nudge_bad_mouthing_notification_54" = "¿Quién se beneficia de tus palabras duras?";
"nudge_bad_mouthing_notification_55" = "Atrápate antes de chismear.";
"nudge_bad_mouthing_notification_56" = "Deja a las personas mejor de como las encontraste.";
