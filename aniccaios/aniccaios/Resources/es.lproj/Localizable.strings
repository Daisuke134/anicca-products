"nudge_loneliness_notification_50" = "Saluda a tu vecino.";
"nudge_loneliness_notification_51" = "Las comunidades online cuentan. Encuentra tu gente.";
"nudge_loneliness_notification_52" = "Mereces conexión.";
"nudge_loneliness_notification_53" = "El primer paso es el más difícil. Dalo.";
