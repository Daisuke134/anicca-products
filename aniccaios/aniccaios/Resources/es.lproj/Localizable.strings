"nudge_bad_mouthing_notification_32" = "El chisme crea conexión temporal pero daño duradero.";
"nudge_bad_mouthing_notification_33" = "Los fuertes levantan. Los débiles derrumban.";
"nudge_bad_mouthing_notification_34" = "Antes de hablar: ¿Es verdad? ¿Es amable? ¿Es necesario?";
"nudge_bad_mouthing_notification_35" = "No conoces toda su historia.";
"nudge_bad_mouthing_notification_36" = "Hablar mal no te hará sentir mejor.";
