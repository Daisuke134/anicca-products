{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "language": "japanese",
  "plansDirectory": ".cursor/plans",
  "enableAllProjectMcpServers": true,
  "model": "claude-opus-4-6",
  "maxTurns": 100,
  "contextCompression": true,
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "Bash(git *)",
      "Bash(cd *)",
      "Bash(ls *)",
      "Bash(wc *)",
      "Bash(cat *)",
      "Bash(mkdir *)",
      "Bash(chmod *)",
      "Bash(jq *)",
      "Bash(fastlane *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(openclaw *)",
      "Bash(/opt/homebrew/bin/firecrawl *)",
      "Bash(codex *)",
      "mcp__serena__*",
      "mcp__context7__*",
      "mcp__apple-docs__*",
      "mcp__maestro__*",
      "mcp__pencil__*",
      "mcp__conway__*"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(ssh anicca@*)",
      "Bash(xcodebuild *)"
    ]
  },
  "env": {
    "FASTLANE_SKIP_UPDATE_CHECK": "1",
    "FASTLANE_OPT_OUT_CRASH_REPORTING": "1",
    "LANG": "ja_JP.UTF-8",
    "TZ": "Asia/Tokyo"
  },
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": ".claude/hooks/scripts/session-start.sh",
        "once": true
      }
    ],
    "PreToolUse": [
      {
        "type": "command",
        "command": ".claude/hooks/scripts/pre-tool-lint.sh",
        "matcher": "Edit|Write"
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "command": ".claude/hooks/scripts/post-tool-sound.sh",
        "matcher": "Bash"
      }
    ],
    "Notification": [
      {
        "type": "command",
        "command": ".claude/hooks/scripts/notification-sound.sh"
      }
    ],
    "Stop": [
      {
        "type": "prompt",
        "command": ".claude/hooks/scripts/stop-continue.sh"
      }
    ],
    "PreCompact": [
      {
        "type": "command",
        "command": ".claude/hooks/scripts/pre-compact-backup.sh"
      }
    ],
    "SubagentStop": [
      {
        "type": "command",
        "command": ".claude/hooks/scripts/subagent-stop-validate.sh"
      }
    ],
    "UserPromptSubmit": [
      {
        "type": "command",
        "command": ".claude/hooks/scripts/user-prompt-context.sh"
      }
    ]
  },
  "spinnerVerbs": [
    "考え中",
    "検索中",
    "実装中",
    "テスト中",
    "レビュー中",
    "デプロイ中"
  ],
  "outputStyle": "concise",
  "sandbox": false,
  "statusLine": true
}
