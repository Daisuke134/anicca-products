#!/bin/bash
# ralph.sh — iOS app factory loop
# Source: harrymunro/ralph-wiggum (https://github.com/harrymunro/ralph-wiggum/blob/main/ralph.sh)
# Source: mischasigtermans/ralph (https://github.com/mischasigtermans/ralph) — CC invocation
# Source: snarktank/ralph (https://github.com/snarktank/ralph) — original loop

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
MAX_ITERATIONS="${1:-20}"
MAX_ATTEMPTS_PER_STORY="${MAX_ATTEMPTS_PER_STORY:-5}"
SLACK_CHANNEL="C091G3PKHL2"
PRD_FILE="$SCRIPT_DIR/prd.json"
PROGRESS_FILE="$SCRIPT_DIR/progress.txt"

# Source: Twelve-Factor App (https://12factor.net/config)
if [ -f ~/.config/mobileapp-builder/.env ]; then
  set -a; source ~/.config/mobileapp-builder/.env; set +a
fi

mkdir -p "$SCRIPT_DIR/logs"

# Initialize progress file
# Source: mischasigtermans/ralph — progress.txt format
if [ ! -f "$PROGRESS_FILE" ]; then
  echo "# Ralph Progress Log" > "$PROGRESS_FILE"
  echo "Started: $(date)" >> "$PROGRESS_FILE"
  echo "---" >> "$PROGRESS_FILE"
fi

# Circuit breaker: track attempts per story
# Source: harrymunro/ralph-wiggum
# Quote: "This prevents infinite loops on fundamentally blocked stories"
ATTEMPTS_FILE="$SCRIPT_DIR/.story-attempts"
LAST_STORY_FILE="$SCRIPT_DIR/.last-story"
if [ ! -f "$ATTEMPTS_FILE" ]; then echo "{}" > "$ATTEMPTS_FILE"; fi

get_current_story() {
  jq -r '.userStories[] | select(.passes == false) | .id' "$PRD_FILE" 2>/dev/null | head -1
}
get_story_attempts() {
  jq -r --arg id "$1" '.[$id] // 0' "$ATTEMPTS_FILE" 2>/dev/null || echo "0"
}
increment_story_attempts() {
  local story_id="$1"
  local current=$(get_story_attempts "$story_id")
  local new_count=$((current + 1))
  jq --arg id "$story_id" --argjson count "$new_count" '.[$id] = $count' "$ATTEMPTS_FILE" > "$ATTEMPTS_FILE.tmp" && mv "$ATTEMPTS_FILE.tmp" "$ATTEMPTS_FILE"
  echo "$new_count"
}
mark_story_skipped() {
  local story_id="$1"
  local note="Skipped: exceeded $2 attempts without passing"
  jq --arg id "$story_id" --arg note "$note" \
    '.userStories = [.userStories[] | if .id == $id then .notes = $note else . end]' \
    "$PRD_FILE" > "$PRD_FILE.tmp" && mv "$PRD_FILE.tmp" "$PRD_FILE"
  echo "⚠️ Circuit breaker: $story_id skipped after $2 attempts"
}

notify_slack() {
  source ~/.config/mobileapp-builder/.env 2>/dev/null
  curl -s -X POST "$SLACK_WEBHOOK_AGENTS" -H 'Content-Type: application/json' -d "{\"text\":\"$1\"}" 2>/dev/null || true
  openclaw message send --channel slack --target "$SLACK_CHANNEL" --text "$1" 2>/dev/null || true
}

echo "🏭 ralph.sh 起動: MAX_ITERATIONS=$MAX_ITERATIONS MAX_ATTEMPTS_PER_STORY=$MAX_ATTEMPTS_PER_STORY"
notify_slack "🏭 ralph.sh 起動: $(basename "$SCRIPT_DIR")"

PREV_PASSES=""

for i in $(seq 1 $MAX_ITERATIONS); do
  echo ""
  echo "==============================================================="
  echo "  🏭 Iteration $i / $MAX_ITERATIONS — $(date)"
  echo "==============================================================="

  # Circuit breaker check
  # Source: harrymunro/ralph-wiggum
  CURRENT_STORY=$(get_current_story)
  if [ -n "$CURRENT_STORY" ]; then
    LAST_STORY=""
    [ -f "$LAST_STORY_FILE" ] && LAST_STORY=$(cat "$LAST_STORY_FILE" 2>/dev/null || echo "")

    if [ "$CURRENT_STORY" == "$LAST_STORY" ]; then
      ATTEMPTS=$(increment_story_attempts "$CURRENT_STORY")
      echo "  Attempt $ATTEMPTS/$MAX_ATTEMPTS_PER_STORY on $CURRENT_STORY"
      if [ "$ATTEMPTS" -ge "$MAX_ATTEMPTS_PER_STORY" ]; then
        mark_story_skipped "$CURRENT_STORY" "$MAX_ATTEMPTS_PER_STORY"
        notify_slack "⚠️ Circuit breaker: $CURRENT_STORY skipped after $MAX_ATTEMPTS_PER_STORY attempts"
        echo "$CURRENT_STORY" > "$LAST_STORY_FILE"
        sleep 1
        continue
      fi
    else
      [ -n "$CURRENT_STORY" ] && ATTEMPTS=$(increment_story_attempts "$CURRENT_STORY")
      echo "  Starting: $CURRENT_STORY (attempt ${ATTEMPTS:-1}/$MAX_ATTEMPTS_PER_STORY)"
    fi
    echo "$CURRENT_STORY" > "$LAST_STORY_FILE"
  else
    echo "  No incomplete stories found"
  fi

  # Snapshot passes BEFORE CC runs
  BEFORE_PASSES="$PREV_PASSES"

  # Run CC
  # Source: mischasigtermans/ralph — variable + --print argument (not stdin redirect)
  # Quote: "claude --dangerously-skip-permissions --print \"$PROMPT_CONTENT\""
  # Source: ghuntley.com/ralph/ — "use as little context as possible"
  LOG_FILE="$SCRIPT_DIR/logs/iteration-$i.log"

  OUTPUT=$(claude --dangerously-skip-permissions --print < "$SCRIPT_DIR/CLAUDE.md" 2>&1 | tee "$LOG_FILE") || true

  echo ""
  echo "🏭 Iteration $i 終了: $(date)"

  # Detect newly completed US → Slack
  if [ -f "$PRD_FILE" ]; then
    CURR_PASSES=$(python3 -c "
import json
with open('$PRD_FILE') as f: d = json.load(f)
for us in d['userStories']:
    if us['passes']: print(us['id'] + ': ' + us['title'])
" 2>/dev/null || true)

    while IFS= read -r line; do
      if [ -n "$line" ] && ! echo "$PREV_PASSES" | grep -qF "$line"; then
        notify_slack "✅ $line"
      fi
    done <<< "$CURR_PASSES"
    PREV_PASSES="$CURR_PASSES"
  fi

  # EXTERNAL VALIDATION GATE
  # Source: SonarQube — "mandatory evaluations a piece of code must pass before progressing"
  # Source: fastlane deliver — precheck before submit
  if [ -f "$SCRIPT_DIR/validate.sh" ]; then
    echo "🔍 External validation gate..."
    VALIDATE_LOG="$SCRIPT_DIR/logs/validate-$i.log"
    if bash "$SCRIPT_DIR/validate.sh" 2>&1 | tee "$VALIDATE_LOG"; then
      echo "🟢 Validation PASSED"
    else
      echo "🔴 Validation FAILED — resetting newly completed US"
      python3 << PYEOF
import json
with open('$PRD_FILE') as f: d = json.load(f)
before = set('''$BEFORE_PASSES'''.strip().split('\n')) if '''$BEFORE_PASSES'''.strip() else set()
for us in d['userStories']:
    line = us['id'] + ': ' + us['title']
    if us['passes'] and line not in before:
        us['passes'] = False
        us['notes'] = (us.get('notes','') + ' | VALIDATION_FAILED').strip()
        print(f'🔴 Reset {us["id"]} to passes:false')
with open('$PRD_FILE','w') as f: json.dump(d, f, indent=2)
PYEOF
      notify_slack "🔴 Validation FAILED: external gate rejected — factory stopped"
      exit 1  # STOP factory on validation failure
    fi
  fi

  # COMPLETE signal — double verification
  # Source: harrymunro/ralph-wiggum
  # Quote: "Verify all stories actually have passes:true"
  if echo "$OUTPUT" | grep -q "<promise>COMPLETE</promise>"; then
    echo "🏭 COMPLETE signal detected. Verifying..."
    INCOMPLETE=$(jq -r '.userStories[] | select(.passes == false) | .id' "$PRD_FILE" 2>/dev/null || echo "")
    if [ -z "$INCOMPLETE" ]; then
      echo "🏭 ✅ Verification passed: all stories passes:true"
      notify_slack "🎉 全 US 完了！App Store に提出しました。"
      exit 0
    else
      echo "🏭 ⚠️ COMPLETE claimed but verification FAILED!"
      echo "   Incomplete: $INCOMPLETE"
      echo "   Continuing..."
      notify_slack "⚠️ COMPLETE claimed but $INCOMPLETE still passes:false. Continuing."
    fi
  fi

  sleep 2
done

echo "🏭 ❌ MAX_ITERATIONS ($MAX_ITERATIONS) reached"
notify_slack "❌ MAX_ITERATIONS ($MAX_ITERATIONS) 到達。完了せず。"
exit 1
