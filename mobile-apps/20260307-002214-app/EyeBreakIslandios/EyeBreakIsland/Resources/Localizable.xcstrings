{
  "sourceLanguage" : "en",
  "strings" : {
    "onboarding.welcome.title" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your Eyes Need Breaks"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "目に休憩を"
          }
        }
      }
    },
    "onboarding.welcome.subtitle" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "65%% of screen workers experience digital eye strain. The 20-20-20 rule is proven to help."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "画面作業者の65%%がデジタル眼精疲労を経験しています。20-20-20ルールは効果が実証されています。"
          }
        }
      }
    },
    "onboarding.feature.title" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Always Visible Timer"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "常に見えるタイマー"
          }
        }
      }
    },
    "onboarding.feature.subtitle" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "EyeBreakIsland keeps a countdown in your Dynamic Island. Impossible to ignore."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "EyeBreakIslandはDynamic Islandにカウントダウンを表示。見逃すことはありません。"
          }
        }
      }
    },
    "onboarding.notification.title" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stay Reminded"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "リマインダーを受け取る"
          }
        }
      }
    },
    "onboarding.notification.subtitle" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Get reminded even when the app is in the background."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "アプリがバックグラウンドでも通知でお知らせします。"
          }
        }
      }
    },
