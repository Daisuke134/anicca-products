default_platform(:ios)

platform :ios do
  desc "Set app version"
  lane :set_version do |options|
    version = options[:version]
    increment_version_number(
      version_number: version,
      xcodeproj: "AffirmFlow.xcodeproj"
    )
    increment_build_number(
      build_number: Time.now.strftime("%Y%m%d%H%M"),
      xcodeproj: "AffirmFlow.xcodeproj"
    )
  end

  desc "Run tests"
  lane :test do
    run_tests(
      scheme: "AffirmFlow",
      device: "iPhone 17 Pro",
      clean: true
    )
  end

  desc "Unlock keychain before signing"
  lane :unlock_keychain_for_signing do
    unlock_keychain(
      path: File.expand_path("~/Library/Keychains/build.keychain-db"),
      password: ENV["KEYCHAIN_PASSWORD"] || "Dukkha2026!"
    )
  end

  desc "Build for App Store"
  lane :build do
    unlock_keychain_for_signing

    update_code_signing_settings(
      use_automatic_signing: false,
      path: "AffirmFlow.xcodeproj",
      team_id: "S5U8UH3JLJ",
      code_sign_identity: "iPhone Distribution",
      targets: ["AffirmFlow"],
      profile_name: "AffirmFlow AppStore"
    )
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "AffirmFlow.xcodeproj",
      team_id: "S5U8UH3JLJ",
      code_sign_identity: "iPhone Distribution",
      targets: ["AffirmFlowWidget"],
      profile_name: "AffirmFlow Widget AppStore"
    )

    build_app(
      scheme: "AffirmFlow",
      output_directory: "./build",
      output_name: "AffirmFlow.ipa",
      export_method: "app-store",
      clean: true,
      export_options: {
        signingStyle: "manual",
        teamID: "S5U8UH3JLJ",
        provisioningProfiles: {
          "com.anicca.affirmflow" => "AffirmFlow AppStore",
          "com.anicca.affirmflow.widget" => "AffirmFlow Widget AppStore"
        }
      }
    )
  end

  desc "Upload to App Store Connect"
  lane :upload do
    upload_to_app_store(
      ipa: "./build/AffirmFlow.ipa",
      skip_metadata: true,
      skip_screenshots: true,
      skip_app_version_update: true,
      force: true,
      run_precheck_before_submit: false,
      precheck_include_in_app_purchases: false,
      api_key_path: File.expand_path("~/.asc/fastlane-api-key.json")
    )
  end

  desc "Build + Upload"
  lane :release do
    build
    upload
  end

  desc "Build for simulator"
  lane :build_for_simulator do
    build_app(
      scheme: "AffirmFlow",
      destination: "generic/platform=iOS Simulator",
      configuration: "Debug",
      skip_archive: true
    )
  end

  desc "Build for device"
  lane :build_for_device do
    unlock_keychain_for_signing

    build_app(
      scheme: "AffirmFlow",
      export_method: "development",
      output_directory: "./build",
      output_name: "AffirmFlow-dev.ipa",
      xcargs: "-allowProvisioningUpdates"
    )

    sh("ios-deploy --bundle ../build/AffirmFlow-dev.ipa || echo 'No device connected'")
  end
end
