default_platform(:ios)

platform :ios do
  PROJECT_NAME    = "ThankfulGratitudeApp"
  SCHEME          = "ThankfulGratitudeApp"
  BUNDLE_ID       = "app.rork.thankful-gratitude-app"
  TEAM_ID         = "S5U8UH3JLJ"
  APP_ID          = "6759514159"
  GREENLIGHT_BIN  = "/tmp/greenlight/build/greenlight"
  PROJECT_DIR     = File.expand_path("..", __dir__)

  API_KEY_ID      = "D637C7RGFN"
  API_ISSUER_ID   = "f53272d9-c12d-4d9d-811c-4eb658284e74"
  API_KEY_PATH    = File.expand_path("~/Downloads/AuthKey_D637C7RGFN.p8")

  def get_api_key
    app_store_connect_api_key(
      key_id:      API_KEY_ID,
      issuer_id:   API_ISSUER_ID,
      key_filepath: API_KEY_PATH,
      duration:    1200,
      in_house:    false
    )
  end

  # ── テスト ──────────────────────────────────────────────
  # run_tests は macOS Sequoia で Dir.[] EINTR バグがある。xcodebuild 直接実行で回避。
  # Ref: https://github.com/fastlane/fastlane/issues/22004
  desc "Unit/Integration テストを実行"
  lane :test do
    derived_data = "/tmp/thankful-dd"
    sim_id = sh("xcrun simctl list devices available | grep 'iPhone 16 (' | grep -v Pro | grep -v Plus | grep -v Max | grep -v Plus | head -1 | grep -oE '[A-F0-9-]{36}'", log: false).strip
    UI.user_error!("iPhone 16 simulator not found") if sim_id.empty?

    sh(
      "xcodebuild test " \
      "-scheme '#{SCHEME}' " \
      "-project '#{PROJECT_DIR}/ThankfulGratitudeApp.xcodeproj' " \
      "-destination 'platform=iOS Simulator,id=#{sim_id}' " \
      "-derivedDataPath '#{derived_data}' " \
      "DEVELOPMENT_TEAM=#{TEAM_ID} " \
      "2>&1 | xcpretty --color || xcodebuild test " \
      "-scheme '#{SCHEME}' " \
      "-project '#{PROJECT_DIR}/ThankfulGratitudeApp.xcodeproj' " \
      "-destination 'platform=iOS Simulator,id=#{sim_id}' " \
      "-derivedDataPath '#{derived_data}' " \
      "DEVELOPMENT_TEAM=#{TEAM_ID} " \
      "2>&1 | tail -20"
    )
    UI.success("✅ All tests passed!")
  end

  # ── シミュレータビルド ──────────────────────────────────
  desc "シミュレータでビルド&起動"
  lane :build_for_simulator do
    xcodebuild(
      scheme:      SCHEME,
      project:     "#{PROJECT_DIR}/ThankfulGratitudeApp.xcodeproj",
      destination: "platform=iOS Simulator,name=iPhone 16,OS=latest",
      build_settings: {
        "DEVELOPMENT_TEAM" => TEAM_ID
      }
    )
    UI.success("✅ Simulator build complete!")
  end

  # ── App Store ビルド ────────────────────────────────────
  desc "App Store 用 IPA をビルド"
  lane :build do
    build_app(
      scheme:  SCHEME,
      project: "#{PROJECT_DIR}/ThankfulGratitudeApp.xcodeproj",
      export_method: "app-store",
      export_options: {
        method:            "app-store",
        teamID:            TEAM_ID,
        signingStyle:      "automatic",
        uploadBitcode:     false,
        uploadSymbols:     true,
        stripSwiftSymbols: true,
      },
      clean: true,
      output_directory: "#{PROJECT_DIR}/build",
      output_name:      "ThankfulGratitudeApp.ipa",
    )
    UI.success("✅ IPA built: #{lane_context[SharedValues::IPA_OUTPUT_PATH]}")
  end

  # ── アップロード ────────────────────────────────────────
  desc "App Store Connect へアップロード"
  lane :upload do
    api_key  = get_api_key
    ipa_path = lane_context[SharedValues::IPA_OUTPUT_PATH] ||
               "#{PROJECT_DIR}/build/ThankfulGratitudeApp.ipa"
    UI.user_error!("IPA not found. Run 'fastlane build' first.") unless File.exist?(ipa_path)

    upload_to_app_store(
      api_key:                        api_key,
      ipa:                            ipa_path,
      skip_metadata:                  true,
      skip_screenshots:               true,
      force:                          true,
      run_precheck_before_submit:     false,
      precheck_include_in_app_purchases: false
    )
    UI.success("✅ Upload complete!")
  end

  # ── Greenlight プリフライト ─────────────────────────────
  desc "Greenlight でプリフライトチェック (CRITICAL=0 必須)"
  lane :preflight do
    unless File.exist?(GREENLIGHT_BIN)
      UI.important("⚠️  Greenlight not found. Installing...")
      sh("cd /tmp && git clone https://github.com/RevylAI/greenlight.git && cd greenlight && make build")
    end

    result = sh("#{GREENLIGHT_BIN} preflight #{PROJECT_DIR} 2>&1", log: true)

    criticals = result.scan(/CRITICAL/i).count
    if criticals > 0
      UI.user_error!("❌ Greenlight: #{criticals} CRITICAL issue(s) found. Fix before submitting.")
    end
    UI.success("✅ Greenlight: CRITICAL=0. OK to submit.")
  end

  # ── 審査提出 ────────────────────────────────────────────
  desc "App Store 審査に提出"
  lane :submit_review do
    api_key = get_api_key

    deliver(
      api_key:            api_key,
      app_identifier:     BUNDLE_ID,
      submit_for_review:  true,
      automatic_release:  false,
      force:              true,
      skip_metadata:      true,
      skip_screenshots:   true,
      run_precheck_before_submit: false,
      submission_information: {
        add_id_info_uses_idfa:                   false,
        add_id_info_serves_ads:                  false,
        add_id_info_tracks_install:              false,
        add_id_info_tracks_action:               false,
        add_id_info_limits_tracking:             false,
        export_compliance_uses_encryption:       false,
        export_compliance_is_exempt:             true,
        content_rights_has_rights:               true,
        content_rights_contains_third_party_content: false
      }
    )
    UI.success("✅ Submitted for review!")
  end

  # ── フルリリース（プリフライト → ビルド → アップロード → 審査） ──
  desc "フルリリース: preflight → build → upload → submit"
  lane :safe_release do
    UI.important("🚀 Starting safe_release for Thankful Gratitude App v#{get_version_number(xcodeproj: "#{PROJECT_DIR}/ThankfulGratitudeApp.xcodeproj")}")

    # GATE 1: Greenlight
    preflight

    # GATE 2: テスト
    test

    # GATE 3: ビルド & アップロード
    build
    upload

    # GATE 4: 審査提出
    submit_review

    UI.success("🎉 safe_release complete! App submitted for review.")
  end

  desc "バージョン番号を更新"
  lane :set_version do |options|
    version = options[:version]
    UI.user_error!("version parameter required") unless version

    increment_version_number(
      version_number: version,
      xcodeproj: "#{PROJECT_DIR}/ThankfulGratitudeApp.xcodeproj"
    )
    UI.success("✅ Version updated to #{version}")
  end
end
